{
  "manifest_version": 3,
  "name": "AutoGrabber",
  "version": "1.4",
  "description": "Captures Authorization Bearer tokens from the CRM agent backoffice (dev + staging), with optional background auto-login.",
  "permissions": ["webRequest", "storage"],
  "host_permissions": [
    "https://bo-customertools2.k8s.eur-sec.dev-novibet.systems/*",
    "https://bo-customertools2.stg-novibet.systems/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://bo-customertools2.k8s.eur-sec.dev-novibet.systems/*",
        "https://bo-customertools2.stg-novibet.systems/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoGrabber",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
